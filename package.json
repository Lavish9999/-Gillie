{
  "name": "gillie",
  "version": "1.0.0",
  "private": true,
  "description": "Gillie quit-vaping wellness companion.",
  "scripts": {
    "prepare:cap": "node scripts/prepare-capacitor-web.js",
    "cap:sync:ios": "npm run prepare:cap && npx cap sync ios",
    "cap:open:ios": "npx cap open ios",
    "icons:ios": "powershell -ExecutionPolicy Bypass -File scripts/generate-ios-icons.ps1",
    "validate:phase1": "node --check phase1-runtime.js && node --check scripts/prepare-capacitor-web.js && npm run prepare:cap"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/local-notifications": "^8.0.0"
  }
}
